{
  "name": "serveless",
  "version": "1.0.0",
  "description": "Serverless Lambda behind ALB using LocalStack and Terraform",
  "main": "handler.js",
  "type": "commonjs",
  "scripts": {
    "infra:init": "npm run infra:init:local",
    "infra:init:local": "set -a; [ -f .env ] && . ./.env; [ -f .env.local ] && . ./.env.local; [ -f .env.network ] && . ./.env.network; set +a; tflocal -chdir=terraform init",
    "infra:apply": "npm run infra:apply:local",
    "infra:apply:local": "set -a; [ -f .env ] && . ./.env; [ -f .env.local ] && . ./.env.local; [ -f .env.network ] && . ./.env.network; set +a; tflocal -chdir=terraform apply -auto-approve && ./scripts/terraform-outputs-to-env.sh",
    "infra:destroy": "npm run infra:destroy:local",
    "infra:destroy:local": "set -a; [ -f .env ] && . ./.env; [ -f .env.local ] && . ./.env.local; [ -f .env.network ] && . ./.env.network; set +a; tflocal -chdir=terraform destroy -auto-approve && rm -f .env.network",
    "deploy": "npm run deploy:local",
    "deploy:local": "set -a; [ -f .env ] && . ./.env; [ -f .env.local ] && . ./.env.local; [ -f .env.network ] && . ./.env.network; set +a; sls deploy --stage ${STAGE:-local}",
    "remove": "npm run remove:local",
    "remove:local": "set -a; [ -f .env ] && . ./.env; [ -f .env.local ] && . ./.env.local; [ -f .env.network ] && . ./.env.network; set +a; sls remove --stage ${STAGE:-local}",
    "print": "npm run print:local",
    "print:local": "set -a; [ -f .env ] && . ./.env; [ -f .env.local ] && . ./.env.local; [ -f .env.network ] && . ./.env.network; set +a; sls print --stage ${STAGE:-local}",
    "doctor:env": "set -a; [ -f .env ] && . ./.env; [ -f .env.local ] && . ./.env.local; [ -f .env.network ] && . ./.env.network; set +a; echo STAGE=$STAGE; echo AWS_ENDPOINT_URL=$AWS_ENDPOINT_URL; echo SERVERLESS_DEPLOYMENT_BUCKET=$SERVERLESS_DEPLOYMENT_BUCKET; echo HTTP_LISTENER_ARN=$HTTP_LISTENER_ARN; echo VPC_ID=$VPC_ID; echo SUBNET_ID_1=$SUBNET_ID_1; echo SUBNET_ID_2=$SUBNET_ID_2; echo SECURITY_GROUP_ID=$SECURITY_GROUP_ID"
  },
  "engines": {
    "node": ">=20 <25"
  },
  "dependencies": {},
  "devDependencies": {
    "serverless": "^4.36.1",
    "serverless-localstack": "^1.4.0",
    "serverless-deployment-bucket": "^1.6.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
